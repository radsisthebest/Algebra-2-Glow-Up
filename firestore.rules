rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email in [
          "radhikatchandra@outlook.com",
          "radhika.t.chandra13@gmail.com",
          "ranveer.chandra@gmail.com"
        ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/examResults/{resultId} {
      allow read, create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /premiumRequests/{requestId} {
      allow create, update: if isOwner(requestId);
      allow read, update, delete: if isAdmin();
    }

    match /usage/{usageId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /adminAudit/{auditId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
